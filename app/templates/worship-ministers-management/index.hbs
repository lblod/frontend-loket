<AuToolbar @size="large" @nowrap="true" as |Group|>
  <Group>
    <AuHeading @skin="2">Bedienarenbeheer</AuHeading>
  </Group>
  {{#unless this.currentSession.hasViewOnlyWorshipMinistersManagementData}}
    <Group>
      <AuLink @route="worship-ministers-management.new" @skin="button">
        Voeg bedienaar toe
      </AuLink>
    </Group>
  {{/unless}}
</AuToolbar>

<AuToolbar @size="large" as |Group|>
  <Group />
  <Group class="au-u-1-3@medium">
    <EredienstMandatenbeheer::VendorSelector
      @options={{this.vendorOptions}}
      @selectedVendor={{this.selectedVendor}}
      @onSelect={{this.selectVendor}}
    />
  </Group>
</AuToolbar>

<AuAlert @skin="info" @icon="info-circle" @size="small">
  Foutje in de gegevens? Contacteer ons gerust, dan zetten we dit samen recht.
  U vindt onze contactgegevens onder het icoontje
  <AuIcon @icon="question-circle" />, bovenaan de pagina.
</AuAlert>

<AuAlert @skin="info" @icon="manual" @size="small">
  Meer informatie vindt u in de
  <AuLinkExternal
    href="https://abb-vlaanderen.gitbook.io/handleiding-bedienarenbeheer"
  >handleiding</AuLinkExternal>.</AuAlert>

<AuDataTable
  @content={{this.model}}
  @isLoading={{this.isLoadingModel}}
  @noDataMessage="Geen bedienaren gevonden"
  @sort={{this.sort}}
  @page={{this.page}}
  @size={{this.size}}
  as |t|
>
  <t.content as |c|>
    <c.header>
      <AuDataTableThSortable
        @field=":no-case:ministerPosition.function.label"
        @currentSorting={{this.sort}}
        @label="Functienaam"
      />
      <AuDataTableThSortable
        @field=":no-case:person.gebruikteVoornaam"
        @currentSorting={{this.sort}}
        @label="Voornaam"
      />
      <AuDataTableThSortable
        @field=":no-case:person.achternaam"
        @currentSorting={{this.sort}}
        @label="Achternaam"
      />
      <AuDataTableThSortable
        @field="agentStartDate"
        @currentSorting={{this.sort}}
        @label="Startdatum"
      />
      <AuDataTableThSortable
        @field="agentEndDate"
        @currentSorting={{this.sort}}
        @label="Einddatum"
      />
      <th>Bron</th>
      <th class="u-table-cell-shrink-content">
        <span class="au-u-hidden-visually">Bedienaar bewerken</span>
      </th>
    </c.header>
    <c.body as |minister|>
      <td>{{minister.ministerPosition.function.label}}</td>
      <td>{{minister.person.gebruikteVoornaam}}</td>
      <td>{{minister.person.achternaam}}</td>
      <td>{{moment-format minister.agentStartDate "DD-MM-YYYY"}}</td>
      <td>{{moment-format minister.agentEndDate "DD-MM-YYYY"}}</td>
      <td>{{if minister.provenance.name minister.provenance.name "Loket lokale besturen"}}</td>
      <td class="u-table-cell-fit-content">
        {{#if this.currentSession.hasViewOnlyWorshipMinistersManagementData}}
          <AuLink
            @icon="eye"
            @iconAlignment="left"
            @skin="primary"
            @route="worship-ministers-management.minister.details"
            @model={{minister.id}}
          >
            Bekijk
          </AuLink>
        {{else}}
          <AuLink
            @icon="pencil"
            @iconAlignment="left"
            @skin="primary"
            @route="worship-ministers-management.minister.edit"
            @model={{minister.id}}
          >
            Bewerk
          </AuLink>
        {{/if}}
      </td>
    </c.body>
  </t.content>
</AuDataTable>