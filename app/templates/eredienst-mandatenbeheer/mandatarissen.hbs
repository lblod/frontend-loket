<div class="au-c-body-container">
  <AuToolbar
    @size="large"
    @nowrap="true"
    class="au-u-padding-bottom-none"
    as |Group|
  >
    <Group>
      <div class="au-o-flow">
        <AuHeading @skin="2">Mandatenbeheer</AuHeading>
      </div>
    </Group>
    {{#unless this.currentSession.hasViewOnlyWorshipMandateesManagementData}}
      <Group>
        <AuButtonGroup>
          <AuLink @route="eredienst-mandatenbeheer.new" @skin="button">Voeg
            mandataris toe</AuLink>
        </AuButtonGroup>
      </Group>
    {{/unless}}
  </AuToolbar>

  <AuToolbar @size="large" as |Group|>
    <Group>
      <div class="">
        <EredienstMandatenbeheer::BestuursperiodenSelector
          @options={{this.mandatenbeheer.bestuursperiods}}
          @selectedPeriod={{this.mandatenbeheer.selectedPeriod}}
          @onSelect={{this.selectPeriod}}
        />
      </div>
    </Group>
    <Group class="au-u-1-3@medium">
      <AuInput
        @icon="search"
        @width="block"
        value={{this.searchData}}
        placeholder="Zoek mandataris"
        {{on "input" (perform this.search value="target.value")}}
      />
    </Group>
    <Group class="au-u-1-3@medium">
      <EredienstMandatenbeheer::VendorSelector
        @selectedVendor={{this.vendorId}}
        @onSelect={{this.selectVendor}}
      />
    </Group>
    <Group>
      <AuToggleSwitch @checked={{this.active}} @onChange={{this.toggleActive}}>
        Toon enkel actieve mandatarissen
      </AuToggleSwitch>
      {{#if this.currentSession.isAdmin}}
        <AuToggleSwitch
          @checked={{this.showInvalidated}}
          @onChange={{fn (mut this.showInvalidated)}}
        >
          Toon verborgen mandatarissen
        </AuToggleSwitch>
      {{/if}}
    </Group>
  </AuToolbar>

  <AuAlert @skin="info" @icon="info-circle" @size="small">
    Foutje in de gegevens? Contacteer ons gerust, dan zetten we dit samen recht.
    U vindt onze contactgegevens in de helpsectie, bovenaan de pagina.
  </AuAlert>

  <AuAlert @skin="warning" @icon="alert-triangle" @size="small">Gelieve
    Bestuursleden met mandaten Penningmeester, Secretaris of Voorzitter ook
    afzonderlijk als bestuurslid toe te voegen. Meer informatie over waarom deze
    als twee aparte posities gezien worden vindt u in de
    <AuLinkExternal
      href="https://abb-vlaanderen.gitbook.io/handleiding-mandatenbeheer-erediensten/handleiding-mandatenbeheer/hoe-gebruik-ik-de-applicatie#wat-zijn-de-verschillende-bestuursmandaten"
    >handleiding</AuLinkExternal>.</AuAlert>

  <AuDataTable
    @content={{this.model}}
    @isLoading={{this.isLoading}}
    @noDataMessage="Geen mandatarissen gevonden"
    @sort={{this.sort}}
    @page={{this.page}}
    @size={{this.size}}
    as |t|
  >
    <t.content as |c|>
      <c.header>
        {{#if (and this.currentSession.isAdmin this.showHidden)}}
          <th>Info</th>
        {{/if}}

        <th class="au-u-visible-small-up">Orgaan</th>
        <AuDataTableThSortable
          @field=":no-case:isBestuurlijkeAliasVan.gebruikteVoornaam"
          @currentSorting={{this.sort}}
          @label="Naam"
          class="au-u-visible-small-up"
        />
        <AuDataTableThSortable
          @field=":no-case:isBestuurlijkeAliasVan.achternaam"
          @currentSorting={{this.sort}}
          @label="Familienaam"
        />
        <AuDataTableThSortable
          @field=":no-case:bekleedt.bestuursfunctie.label"
          @currentSorting={{this.sort}}
          @label="Mandaat"
        />
        <AuDataTableThSortable
          @field="start"
          @currentSorting={{this.sort}}
          @label="Startdatum"
          class="au-u-visible-medium-up"
        />
        <AuDataTableThSortable
          @field="einde"
          @currentSorting={{this.sort}}
          @label="Einddatum"
          class="au-u-visible-medium-up"
        />
        <th>Bron</th>
        <th></th>
        {{#if this.currentSession.isAdmin}}
          <th class="u-table-cell-shrink-content">
            <span class="au-u-hidden-visually">Administratieve acties</span>
          </th>
        {{/if}}
      </c.header>
      <c.body data-test-loket="mandatarissen-body" as |mandataris|>
        {{#if (and this.currentSession.isAdmin this.showHidden)}}
          <td>
            {{#if mandataris.deleted}}
              Verwijderd
            {{else}}
              {{! TODO, check if duplicate and display a badge }}
              Duplicaat of normaal
            {{/if}}
          </td>
        {{/if}}
        <td class="au-u-visible-small-up">
          {{#each
            (get this.mandatarisBestuursorganen mandataris.id)
            as |bestuursorgaan index|
          }}
            {{#if (gt index 0)}}<br />{{/if}}
            {{bestuursorgaan.naam}}
          {{/each}}
        </td>
        <td class="au-u-visible-small-up">
          {{mandataris.isBestuurlijkeAliasVan.gebruikteVoornaam}}
        </td>
        <td>
          {{mandataris.isBestuurlijkeAliasVan.achternaam}}
        </td>
        <td>
          {{mandataris.bekleedt.bestuursfunctie.label}}
          {{#let
            (get this.mandatarisActivePeriods mandataris.id)
            as |activePeriodsLabel|
          }}
            {{#if activePeriodsLabel}}
              <div class="au-u-h6 au-u-muted">{{activePeriodsLabel}}</div>
            {{/if}}
          {{/let}}
          <div class="au-u-h-functional au-u-muted">
            Voor meer informatie hieromtrent, kan u de helpsectie te
            consulteren.
          </div>
        </td>
        <td class="au-u-visible-medium-up">{{moment-format
            mandataris.start
            "DD-MM-YYYY"
          }}</td>
        <td class="au-u-visible-medium-up">{{moment-format
            mandataris.einde
            "DD-MM-YYYY"
          }}</td>
        <td>{{if
            mandataris.provenance.name
            mandataris.provenance.name
            "Loket voor lokale besturen"
          }}</td>
        <td>
          {{! Fixing mixed situations, hence the OR. TODO: maybe rethink the view only mode }}
          {{#if
            (or
              this.currentSession.hasViewOnlyWorshipMandateesManagementData
              mandataris.provenance.id
              mandataris.invalidation
            )
          }}
            <AuLink
              @route="eredienst-mandatenbeheer.mandataris.details"
              @model={{mandataris.id}}
            >Bekijk</AuLink>
          {{else}}
            <AuLink
              @route="eredienst-mandatenbeheer.mandataris.edit"
              @model={{mandataris.id}}
            >Bewerk</AuLink>
          {{/if}}
        </td>
        {{#if this.currentSession.isAdmin}}
          <td>
            <div class="au-u-flex au-u-flex--end">
              {{#if mandataris.invalidation}}
                {{#if (is-mandataris-deleted mandataris)}}
                  <AuPill @skin="error" @icon="bin" @size="small">
                    Verwijderd
                  </AuPill>
                {{else}}
                  <AuPill @skin="warning" @icon="copy" @size="small">
                    Duplicaat
                  </AuPill>
                {{/if}}
              {{/if}}
              <AuDropdown
                @title="Acties"
                @icon={{component "icons/nav-show-more-vertical"}}
                @hideText={{true}}
                role="menu"
              >
                {{#if mandataris.invalidation}}
                  <AuButton
                    @skin="link"
                    @icon="undo"
                    role="menuitem"
                    {{on "click" (fn this.revertInvalidation mandataris)}}
                  >
                    {{#if (is-mandataris-deleted mandataris)}}
                      Verwijderen ongedaan maken
                    {{else}}
                      Duplicaat status verwijderen
                    {{/if}}
                  </AuButton>
                {{else}}
                  <AuButton
                    @skin="link"
                    @icon="archive"
                    role="menuitem"
                    {{on "click" (fn this.markAsDuplicate mandataris)}}
                  >
                    Markeren als duplicaat
                  </AuButton>
                  <AuButton
                    @skin="link"
                    @icon="trash"
                    @alert={{true}}
                    role="menuitem"
                    {{on "click" (fn this.softDelete mandataris)}}
                  >
                    Verwijderen
                  </AuButton>
                {{/if}}
              </AuDropdown>
            </div>
          </td>
        {{/if}}
      </c.body>
    </t.content>
  </AuDataTable>
</div>

{{#if this.mandatarisForInvalidation}}
  <EredienstMandatenbeheer::InvalidateMandataris
    @mandataris={{this.mandatarisForInvalidation}}
    @mandatarissen={{this.model}}
    @invalidationType={{this.invalidationType}}
    @onComplete={{this.handleInvalidationComplete}}
    @onCancel={{this.hideInvalidationModal}}
  />
{{/if}}