<Await @promise={{@model.dataPromise}}>
  <:pending>
    <IpdcServiceSidepanel
      @loading={{true}}
      @onClose={{this.closeDetail}}
    />
  </:pending>

  <:success as |result|>
    <IpdcServiceSidepanel
      @publicService={{result.publicService}}
      @primaryWebsite={{result.primaryWebsite}}
      @otherWebsites={{result.otherWebsites}}
      @onClose={{this.closeDetail}}
    />
  </:success>
</Await>